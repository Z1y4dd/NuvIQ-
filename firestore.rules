rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Datasets collection - users can only access their own datasets
    match /datasets/{datasetId} {
      // get (single doc): verify ownership via document data
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      // list (collection query): allow any authenticated user
      // (the client query already filters by userId == auth.uid)
      allow list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;

      // Forecasts subcollection
      match /forecasts/{forecastId} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/datasets/$(datasetId)).data.userId == request.auth.uid;
      }

      // Association rules subcollection
      match /associationRules/{ruleId} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/datasets/$(datasetId)).data.userId == request.auth.uid;
      }
    }
  }
}
