rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // CSV files in user-specific directories
    match /datasets/{userId}/{fileName} {
      // Allow authenticated users to read/write only their own files
      // Note: Download URLs with tokens can bypass these rules
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.contentType.matches('text/csv');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
